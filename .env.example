# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ai_server_copilot

# Security
SECRET_KEY=  # Generate with: openssl rand -hex 32
ENCRYPTION_KEY=  # Generate 32-byte base64 string: openssl rand -base64 32
KNOWN_HOSTS_FILE=  # Path to known_hosts file, e.g., /home/user/.ssh/known_hosts

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# App
DEBUG=false
ENVIRONMENT=production
